{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "module": "es2022",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "lib": ["es2022", "dom"],
    "verbatimModuleSyntax": false,
    "customConditions": []
  },
  "angularCompilerOptions": {
    "compilationMode": "partial"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
